{
  "name": "@legion/artifacts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:schemas": "pnpm run build && node scripts/generate-artifacts-json-schema.mjs",
    "test": "pnpm --filter @legion/protocol build && pnpm run generate:schemas && node --test --test-reporter=spec \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "@legion/protocol": "workspace:*",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
