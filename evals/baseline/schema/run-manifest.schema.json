{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "run_id", "scenario_id", "host", "model", "adapter", "repeat", "baseline_commit", "fixture_hashes", "timestamps", "telemetry", "interventions", "events", "terminal_status", "artifacts"],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "host": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "adapter": { "type": "string", "minLength": 1 },
    "repeat": { "type": "integer", "minimum": 1 },
    "baseline_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "fixture_hashes": { "type": "string", "minLength": 1 },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "ended_at"],
      "properties": {
        "started_at": { "type": "string", "minLength": 1 },
        "ended_at": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "telemetry": {
      "type": "object",
      "required": ["tokens", "cost"],
      "properties": {
        "tokens": { "$ref": "#/$defs/telemetry_value" },
        "cost": { "$ref": "#/$defs/telemetry_value" }
      },
      "additionalProperties": false
    },
    "interventions": { "type": "array", "items": { "type": "object" } },
    "events": { "type": "array", "items": { "type": "object" } },
    "terminal_status": { "enum": ["dry-run", "passed", "failed", "interrupted", "blocked"] },
    "artifacts": {
      "type": "object",
      "required": ["transcript", "git_before", "git_after"],
      "properties": {
        "transcript": { "type": "string", "minLength": 1 },
        "git_before": { "type": "string", "minLength": 1 },
        "git_after": { "type": "string", "minLength": 1 },
        "score": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "telemetry_value": {
      "type": "object",
      "required": ["status", "value", "reason"],
      "properties": {
        "status": { "enum": ["available", "unavailable"] },
        "value": { "type": ["number", "null"] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
