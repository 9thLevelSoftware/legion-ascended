              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false
        },
        "decisions": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
              "description": "Relative POSIX artifact path inside an approved artifact root."
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$",
              "description": "Lowercase SHA-256 content hash with sha256: prefix."
            },
            "mediaType": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false
        },
        "oracles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512,
                "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
                "description": "Relative POSIX artifact path inside an approved artifact root."
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$",
                "description": "Lowercase SHA-256 content hash with sha256: prefix."
              },
              "mediaType": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
              }
            },
            "required": [
              "path",
              "sha256"
            ],
            "additionalProperties": false
          }
        },
        "taskgraph": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
              "description": "Relative POSIX artifact path inside an approved artifact root."
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$",
              "description": "Lowercase SHA-256 content hash with sha256: prefix."
            },
            "mediaType": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false
        },
        "evidenceIndex": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
              "description": "Relative POSIX artifact path inside an approved artifact root."
            },
            "sha256": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$",
              "description": "Lowercase SHA-256 content hash with sha256: prefix."
            },
            "mediaType": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
