{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.9thlevelsoftware.com/legion/artifacts/oracle-manifest.schema.json",
  "title": "Legion oracle manifest schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Major.minor.patch schema version without leading zeroes."
    },
    "kind": {
      "type": "string",
      "const": "oracle-manifest"
    },
    "changeId": {
      "type": "string",
      "pattern": "^chg_[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Change ID"
    },
    "oracles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "project-manifest",
              "constitution",
              "current-spec",
              "delta-spec",
              "proposal",
              "design",
              "decision-log",
              "oracle",
              "taskgraph",
              "evidence-index"
            ]
          },
          "artifact": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512,
                "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
                "description": "Relative POSIX artifact path inside an approved artifact root."
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$",
                "description": "Lowercase SHA-256 content hash with sha256: prefix."
              },
              "mediaType": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
              }
            },
            "required": [
              "path",
              "sha256"
            ],
            "additionalProperties": false
          },
          "revision": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "baseGitSha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$",
            "description": "Lowercase 40-character Git object SHA."
          },
          "supersedes": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512,
                "pattern": "^(?!\\/)(?![A-Za-z]:)(?!.*\\\\)(?!.*\\/\\/)(?!.*(?:^|\\/)\\.\\.?(?:\\/|$))[A-Za-z0-9._@+=:,~-]+(?:\\/[A-Za-z0-9._@+=:,~-]+)*$",
                "description": "Relative POSIX artifact path inside an approved artifact root."
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$",
                "description": "Lowercase SHA-256 content hash with sha256: prefix."
              },
              "mediaType": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9.+-]*\\/[a-z0-9][a-z0-9.+-]*$"
              }
            },
            "required": [
              "path",
              "sha256"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "role",
          "artifact",
          "revision"
        ],
        "additionalProperties": false
      }
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "Lowercase SHA-256 content hash with sha256: prefix."
    }
  },
  "required": [
    "schemaVersion",
    "kind",
    "changeId",
    "oracles",
    "manifestHash"
  ],
  "additionalProperties": false
}
